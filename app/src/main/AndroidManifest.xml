<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <queries>
        <package android:name="com.google.android.apps.maps" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/brazukaxi"
        android:label="@string/app_name"
        android:roundIcon="@drawable/brazukaxi"
        android:supportsRtl="true"
        android:theme="@style/Theme.Localiza">

        <activity
            android:name="com.localiza.uniforads.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.localiza.uniforads.AddressListActivity"
            android:exported="false" />

        <activity
            android:name="com.localiza.uniforads.AddAddressActivity"
            android:exported="false" />

        <activity
            android:name="com.localiza.uniforads.AddressDetailActivity"
            android:exported="false" />

        <activity
            android:name="com.localiza.uniforads.RegisterPlaceActivity"
            android:exported="false" />

        <activity
            android:name="com.localiza.uniforads.ShareLocationActivity"
            android:exported="false" />

        <service
            android:name=".MessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>